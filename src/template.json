{
    "$schema": "vscode://schemas/color-theme",
    "name": "{name}",
    "type": "vs-dark",
    "tokenColors": [
        {
            "name": "Keywords and Operators",
            "scope": [
                "keyword",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "{fg}"
            }
        },
        {
            "name": "Strings, constants, numbers, characters",
            "scope": [
                "string",
                "markup.inline.raw"
            ],
            "settings": {
                "foreground": "{fg_subtle}"
            }
        },
        {
            "name": "Comments",
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "{fg_dim}"
            }
        },
        {
            "name": "Errors",
            "scope": "invalid.illegal",
            "settings": {
                "foreground": "{fg}"
            }
        },
        {
            "name": "Sections and headings",
            "scope": "entity.name.section.markdown",
            "settings": {
                "foreground": "{fg}",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Uncolored overrides",
            "scope": [
                "entity.name.tag.yaml",
                "punctuation.section.block",
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "{fg}"
            }
        }
    ],
    "colors": {
